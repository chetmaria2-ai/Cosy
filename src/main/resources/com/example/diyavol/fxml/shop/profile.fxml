<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.2"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.diyavol.controller.shop.profileController"
            style="-fx-background-color: linear-gradient(from 0% 0% to 100% 100%, #8B0000 0%, #2F4F4F 100%);">

    <top>
        <VBox spacing="8" style="-fx-background-color: #2F4F4F; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 3);">
            <Label text="👤 Личный кабинет"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #F5F5DC;"/>
            <Label fx:id="usernameLabel" text="Пользователь"
                   style="-fx-font-size: 14px; -fx-text-fill: #D2B48C;"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-padding: 15;">
            <HBox spacing="20" style="-fx-padding: 15;">

                <!-- ЛЕВАЯ КОЛОНКА: данные и лояльность -->
                <VBox spacing="15" prefWidth="350">

                    <!-- Карточка профиля -->
                    <VBox spacing="12" style="-fx-background-color: rgba(245,245,220,0.95); -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 2);">
                        <Label text="📋 Личные данные"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #8B0000;"/>
                        <TextField fx:id="nameField" promptText="Полное имя"
                                   style="-fx-background-radius: 8; -fx-padding: 8; -fx-font-size: 13px;"/>
                        <TextField fx:id="emailField" promptText="Email"
                                   style="-fx-background-radius: 8; -fx-padding: 8; -fx-font-size: 13px;"/>
                        <TextField fx:id="phoneField" promptText="Телефон"
                                   style="-fx-background-radius: 8; -fx-padding: 8; -fx-font-size: 13px;"/>
                        <PasswordField fx:id="passwordField" promptText="Новый пароль (необязательно)"
                                       style="-fx-background-radius: 8; -fx-padding: 8; -fx-font-size: 13px;"/>
                        <Button fx:id="saveButton" text="💾 Сохранить" onAction="#handleSaveProfile"
                                maxWidth="Infinity"
                                style="-fx-background-color: #2E8B57; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10; -fx-cursor: hand;"/>
                    </VBox>

                    <!-- Программа лояльности -->
                    <VBox spacing="10" style="-fx-background-color: rgba(245,245,220,0.95); -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 2);">
                        <Label text="🌟 Программа лояльности"
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #8B0000;"/>
                        <Label fx:id="loyaltyPoints" text="🌟 0 баллов"
                               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #DAA520;"/>
                        <Label fx:id="loyaltyLevel" text="Уровень: Новичок"
                               style="-fx-font-size: 14px; -fx-text-fill: #555;"/>
                        <ProgressBar fx:id="loyaltyProgress" progress="0.15" maxWidth="Infinity"
                                     style="-fx-accent: #DAA520;"/>
                    </VBox>

                    <!-- Кнопки навигации -->
                    <VBox spacing="10">
                        <Button fx:id="backButton" text="⬅️ Назад в меню" onAction="#handleBackToMain"
                                maxWidth="Infinity"
                                style="-fx-background-color: rgba(245,245,220,0.9); -fx-text-fill: #8B0000; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10; -fx-cursor: hand;"/>
                        <Button fx:id="logoutButton" text="🚪 Выйти из аккаунта" onAction="#handleLogout"
                                maxWidth="Infinity"
                                style="-fx-background-color: #DC143C; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10; -fx-cursor: hand;"/>
                    </VBox>
                </VBox>

                <!-- ПРАВАЯ КОЛОНКА: история, избранное, акции -->
                <VBox spacing="15" HBox.hgrow="ALWAYS">

                    <!-- История заказов -->
                    <VBox spacing="10" style="-fx-background-color: rgba(245,245,220,0.95); -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 2);">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="📦 История заказов"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #8B0000;"/>
                            <Button text="👁️ Просмотр" onAction="#handleViewOrder"
                                    style="-fx-background-color: #4682B4; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 8; -fx-padding: 5 10; -fx-cursor: hand;"/>
                        </HBox>
                        <ListView fx:id="orderHistory" prefHeight="150"/>
                    </VBox>

                    <!-- Избранное -->
                    <VBox spacing="10" style="-fx-background-color: rgba(245,245,220,0.95); -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 2);">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="❤️ Избранное"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #8B0000;"/>
                            <Button text="🗑️ Удалить" onAction="#handleRemoveFavorite"
                                    style="-fx-background-color: #DC143C; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 8; -fx-padding: 5 10; -fx-cursor: hand;"/>
                        </HBox>
                        <ListView fx:id="favoritesList" prefHeight="150"/>
                    </VBox>

                    <!-- Акции -->
                    <VBox spacing="10" style="-fx-background-color: rgba(245,245,220,0.95); -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, 2);">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="🎁 Акции и предложения"
                                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #8B0000;"/>
                            <Button text="✅ Активировать" onAction="#handleActivatePromotion"
                                    style="-fx-background-color: #2E8B57; -fx-text-fill: white; -fx-font-size: 12px; -fx-background-radius: 8; -fx-padding: 5 10; -fx-cursor: hand;"/>
                        </HBox>
                        <ListView fx:id="promotionsList" prefHeight="150"/>
                    </VBox>
                </VBox>
            </HBox>
        </ScrollPane>
    </center>
</BorderPane>
